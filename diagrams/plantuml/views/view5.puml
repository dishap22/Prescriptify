@startuml
!theme plain
skinparam componentStyle rectangle

node "Load Balancer Cluster\n(HAProxy / NGINX)" as LB {
  [SSL Termination]
  [Health Checker]
  [Round Robin Load Balancing]
}

node "Application Layer - Kubernetes Cluster" as APP {
  
  node "Stateless Service Pods" as SERVICES {
    component "PrescriptionStateManager\nInstance 1" as PSM1
    component "PrescriptionStateManager\nInstance 2" as PSM2
    component "PrescriptionStateManager\nInstance 3" as PSM3
    component "Verification Handler\nInstance 1" as VH1
    component "Verification Handler\nInstance 2" as VH2
    component "User Service\nInstance 1" as US1
    component "User Service\nInstance 2" as US2
  }
  
  node "Worker Pods (Async Processing)" as WORKERS {
    component "Notification Worker\n(Horizontal Pod Autoscaler)" as NW
    component "Analytics Worker\n(Horizontal Pod Autoscaler)" as AW
    component "Scheduler Worker" as SW
  }
}

node "Message Broker Cluster" as MQ {
  component "Kafka Broker 1\n(Leader)" as K1
  component "Kafka Broker 2\n(Follower)" as K2
  component "Kafka Broker 3\n(Follower)" as K3
  queue "Durable Topics\n(prescription.events)" as TOPICS
}

node "Database Cluster" as DB_CLUSTER {
  database "Primary DB\n(Read-Write)" as DB_P
  database "Replica 1\n(Read-Only)" as DB_R1
  database "Replica 2\n(Read-Only)" as DB_R2
  component "Automatic Failover\n(Patroni / Orchestrator)" as FO
}

node "Monitoring & Observability Stack" as MON {
  component "Prometheus" as PROM
  component "Grafana" as GRAF
  component "ELK Stack\n(Elasticsearch, Logstash, Kibana)" as ELK
  component "Jaeger\n(Distributed Tracing)" as JGR
}

' === North-South Traffic ===
LB --> PSM1 : HTTPS/gRPC
LB --> PSM2 : HTTPS/gRPC
LB --> PSM3 : HTTPS/gRPC
LB --> VH1 : HTTPS/gRPC
LB --> VH2 : HTTPS/gRPC
LB --> US1 : HTTPS/gRPC
LB --> US2 : HTTPS/gRPC

' === East-West Traffic (Synchronous) ===
VH1 --> PSM1 : internal gRPC
VH2 --> PSM2 : internal gRPC
US1 --> DB_P : authentication queries

' === Event Publishing ===
PSM1 --> K1 : publish
PSM2 --> K2 : publish
PSM3 --> K3 : publish
VH1 --> K1 : publish

' === Event Consumption ===
K1 --> NW : consume
K2 --> AW : consume
K3 --> SW : consume

' === Database Access ===
PSM1 --> DB_P : write (state transitions)
PSM2 --> DB_P : write
VH1 --> DB_R1 : read (verification checks)
VH2 --> DB_R2 : read
NW --> DB_P : write (notification logs)
AW --> DB_P : write (analytics data)

' === Database Replication ===
DB_P --> DB_R1 : synchronous replication
DB_P --> DB_R2 : synchronous replication
FO --> DB_P : health monitoring / failover control

' === Observability ===
PSM1 --> PROM : metrics (/metrics)
PSM2 --> PROM : metrics
K1 --> PROM : metrics
DB_P --> PROM : metrics
PROM --> GRAF : visualization

PSM1 --> ELK : logs
PSM2 --> ELK : logs
K1 --> ELK : logs

PSM1 --> JGR : traces
VH1 --> JGR : traces

' === Notes ===
note top of LB
  Health check every 5 seconds
  Unhealthy instances removed from rotation
  Implements Active Redundancy (Tactic 1)
end note

note top of K1
  Events persisted to disk before acknowledgment
  At-least-once delivery semantics
  Supports ADR 3 (Reliable Async Processing)
  Topic partitions for parallel consumption
end note

note top of DB_P
  Optimistic Concurrency Control (ADR 4)
  Version field prevents lost updates
  Primary-Replica with automatic failover
  Target Recovery Time: < 60 seconds
end note

note right of FO
  Patroni / orchestrator monitors primary health
  Triggers automatic promotion of replica
  Application retries on connection failure
end note

note bottom of PROM
  Alerting rules:
  - PSM latency > 500ms → page on-call
  - Database replication lag > 10s → warning
  - Event bus backlog > 10k messages → scale workers
end note
@enduml