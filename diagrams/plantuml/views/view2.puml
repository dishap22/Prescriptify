@startuml
skinparam classAttributeIconSize 0

' === State Pattern ===
abstract class PrescriptionState {
  # Prescription prescription
  # String stateName
  + {abstract} void onEnter()
  + {abstract} void onExit()
  + {abstract} boolean canTransitionTo(PrescriptionState newState)
  + void setPrescription(Prescription p)
}

class PendingState {
  + void onEnter()
  + void onExit()
  + boolean canTransitionTo(PrescriptionState newState)
}

class ActiveState {
  + void onEnter()
  + void onExit()
  + boolean canTransitionTo(PrescriptionState newState)
}

class DispensedState {
  + void onEnter()
  + void onExit()
  + boolean canTransitionTo(PrescriptionState newState)
}

class ExpiredState {
  + void onEnter()
  + void onExit()
  + boolean canTransitionTo(PrescriptionState newState)
}

class RevokedState {
  + void onEnter()
  + void onExit()
  + boolean canTransitionTo(PrescriptionState newState)
}

' === Core Prescription Class ===
class Prescription {
  - String prescriptionId
  - String patientId
  - String doctorId
  - List~Medicine~ medicines
  - LocalDateTime createdAt
  - PrescriptionState currentState
  - int version
  + String getPrescriptionId()
  + void setState(PrescriptionState state)
  + PrescriptionState getCurrentState()
  + int getVersion()
  + void incrementVersion()
}

' === Builder Pattern ===
class PrescriptionBuilder {
  - String prescriptionId
  - String patientId
  - String doctorId
  - List~Medicine~ medicines
  + PrescriptionBuilder setPrescriptionId(String id)
  + PrescriptionBuilder setPatientId(String id)
  + PrescriptionBuilder setDoctorId(String id)
  + PrescriptionBuilder addMedicine(Medicine m)
  + Prescription build()
}

' === Chain of Responsibility ===
abstract class VerificationHandler {
  # VerificationHandler nextHandler
  + void setNext(VerificationHandler handler)
  + {abstract} boolean verify(Prescription p)
  + boolean handle(Prescription p)
}

class DoctorSignatureHandler {
  + boolean verify(Prescription p)
}

class MedicineInteractionHandler {
  + boolean verify(Prescription p)
}

class DuplicateCheckHandler {
  + boolean verify(Prescription p)
}

' === Relationships ===
PrescriptionState <|-- PendingState
PrescriptionState <|-- ActiveState
PrescriptionState <|-- DispensedState
PrescriptionState <|-- ExpiredState
PrescriptionState <|-- RevokedState

Prescription *--> PrescriptionState : currentState
PrescriptionBuilder ..> Prescription : creates <<create>>

VerificationHandler <|-- DoctorSignatureHandler
VerificationHandler <|-- MedicineInteractionHandler
VerificationHandler <|-- DuplicateCheckHandler

VerificationHandler o--> VerificationHandler : next

note top of PrescriptionState
  onEnter() called when state is entered
  onExit() called when state is exited
  Follows State pattern from GoF
end note

note top of PrescriptionBuilder
  Builder pattern for complex
  prescription creation
end note

note top of VerificationHandler
  Chain of Responsibility pattern
  Handles validation in sequence
end note
@enduml